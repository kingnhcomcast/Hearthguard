{
  "schemaVersion": 1,
  "id": "hearthguard",
  "version": "${version}",
  "name": "Hearthguard",
  "description": "Causes some hostile mobs to flee a lit campfire.",
  "authors": [
    "Me!"
  ],
  "contact": {
    "homepage": "https://fabricmc.net/",
    "sources": "https://github.com/FabricMC/fabric-example-mod"
  },
  "license": "CC0-1.0",
  "icon": "assets/hearthguard/icon.png",
  "environment": "*",
  "entrypoints": {
    "main": [
      "io.drahlek.hearthguard.Hearthguard"
    ],
    "client": [
      "io.drahlek.hearthguard.HearthguardClient"
    ],
    "modmenu": [
      "io.drahlek.hearthguard.config.HearthguardModMenu"
    ]
  },
  "mixins": [
    "hearthguard.mixins.json",
    {
      "config": "hearthguard.client.mixins.json",
      "environment": "client"
    }
  ],
  "depends": {
    "fabricloader": ">=0.18.4",
    "minecraft": "~1.21.11",
    "java": ">=21",
    "fabric-api": "*"
  }
}